generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  MENTOR
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  role           Role
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  mentorProfile  MentorProfile?
  studentProfile StudentProfile?
  
  posts          ForumPost[]
  comments       Comment[]
  
  notifications  Notification[]
  
  sentBookings     Booking[] @relation("StudentBookings")
  receivedBookings Booking[] @relation("MentorBookings")
}

model MentorProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName         String
  lastName          String
  profilePicture    String?
  designation       String
  company           String
  domain            String
  yearsOfExperience Int
  bio               String   @db.Text
  skills            String[]
  graduationYear    Int
  availability      String[] // Array of available days/times, e.g. ["Monday 10AM-12PM"]
  linkedinUrl       String?
  githubUrl         String?
  
  rating            Float    @default(0.0)
  sessionsCompleted Int      @default(0)
}

model StudentProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName      String
  lastName       String
  profilePicture String?
  university     String
  graduationYear Int
  bio            String?  @db.Text
}

model Booking {
  id          String        @id @default(uuid())
  
  studentId   String
  student     User          @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  
  mentorId    String
  mentor      User          @relation("MentorBookings", fields: [mentorId], references: [id], onDelete: Cascade)
  
  date        DateTime
  time        String        // E.g., "10:00 AM - 11:00 AM"
  topic       String
  message     String?       @db.Text
  status      BookingStatus @default(PENDING)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ForumPost {
  id          String    @id @default(uuid())
  title       String
  content     String    @db.Text
  tags        String[]
  likes       Int       @default(0)
  
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  comments    Comment[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Comment {
  id          String    @id @default(uuid())
  content     String    @db.Text
  
  postId      String
  post        ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        String    // e.g., "BOOKING_ACCEPTED", "NEW_COMMENT"
  message     String
  isRead      Boolean   @default(false)
  link        String?
  
  createdAt   DateTime  @default(now())
}
